graph TD
    %% ──────────────────────────────────────────────
    %% Modelo de Presentación — QR Restaurante
    %% Metodología UWE: 9 vistas con flujos de navegación
    %% ──────────────────────────────────────────────

    %% ── Estilos ──
    classDef publica fill:#fef3c7,stroke:#f59e0b,stroke-width:2px,color:#92400e
    classDef cliente fill:#dbeafe,stroke:#3b82f6,stroke-width:2px,color:#1e40af
    classDef restaurante fill:#dcfce7,stroke:#22c55e,stroke-width:2px,color:#166534
    classDef admin fill:#fce7f3,stroke:#ec4899,stroke-width:2px,color:#9d174d

    %% ──────────────────────────────────────────────
    %% VISTAS PÚBLICAS (sin autenticación)
    %% ──────────────────────────────────────────────
    V01["🟠 V-01: Home / Inicio
    Hero · Destacados · Filtros tipoCocina"]

    V02["🟠 V-02: Listado de Restaurantes
    Cards · Ordenación · Grid responsive"]

    V03["🟠 V-03: Detalle de Restaurante
    Info · QR activos · Valoraciones"]

    %% ──────────────────────────────────────────────
    %% VISTAS CLIENTE (rol: CLIENTE)
    %% ──────────────────────────────────────────────
    V04["🔵 V-04: Escaneo QR / Entrada
    Cámara · Acompañantes · Validación"]

    V07["🔵 V-07: Mis Visitas
    Activas · Completadas · Salida"]

    V08["🔵 V-08: Valoración
    Estrellas · Comentario · Prevención duplicados"]

    %% ──────────────────────────────────────────────
    %% VISTAS RESTAURANTE (rol: RESTAURANTE)
    %% ──────────────────────────────────────────────
    V05["🟢 V-05: Registro Restaurante
    Formulario · Geocodificación · QR inicial"]

    V06["🟢 V-06: Panel de Control
    Dashboard KPIs · Aforo · Gestión QR"]

    %% ──────────────────────────────────────────────
    %% VISTAS ADMIN (rol: ADMIN)
    %% ──────────────────────────────────────────────
    V09["🩷 V-09: Reportes de Afluencia
    Métricas · Gráficos · Exportar PDF/CSV"]

    LOGIN["🔐 Login
    JWT · RBAC · 3 roles"]

    %% ──────────────────────────────────────────────
    %% FLUJOS DE NAVEGACIÓN
    %% ──────────────────────────────────────────────

    %% Público → Login
    V01 -->|"Iniciar Sesión"| LOGIN
    V01 -->|"Explorá Restaurantes"| V02
    V02 -->|"Ver Más"| V03
    V02 -->|"Filtro tipoCocina"| V02

    %% Login → Dashboards por rol
    LOGIN -->|"rol CLIENTE"| V07
    LOGIN -->|"rol RESTAURANTE"| V06
    LOGIN -->|"rol ADMIN"| V09

    %% Cliente: flujo principal
    V03 -->|"Escanear QR"| V04
    V04 -->|"Entrada registrada"| V07
    V07 -->|"Registrar Salida"| V07
    V07 -->|"Valorá este restaurante"| V08
    V08 -->|"Valoración enviada"| V07

    %% Restaurante: panel + registro
    V06 -->|"Gestión QR"| V05
    V06 -->|"Generar QR"| V03

    %% Admin: reportes
    V09 -->|"Detalle restaurante"| V03

    %% Navegación transversal
    V01 -.->|"Público"| V03
    V07 -.->|"Volver"| V01
    V06 -.->|"Cerrar sesión"| V01

    %% ── Aplicar clases ──
    class V01,V02,V03 publica
    class V04,V07,V08 cliente
    class V05,V06 restaurante
    class V09 admin
